generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StatusEnum {
  PUBLIC  @map("public")
  PRIVATE @map("private")
  SHARED  @map("shared")
}

enum MarketplaceEntryType {
  META  @map("meta")
  CHUNK @map("chunk")
}

enum TaxCodeEnum {
  SELECT_ONE        @map("Select One")
  GST_0             @map("GST_0")
  GST_18            @map("GST_18")
  GST_3             @map("GST_3")
  GST_40            @map("GST_40")
  GST_5             @map("GST_5")
  GST_APPAREL       @map("GST_APPAREL")
  GST_FOOTWEAR      @map("GST_Footwear")
  GST_OLD_12_NEW_0  @map("GST_Old_12_New_0")
  GST_OLD_12_NEW_5  @map("GST_Old_12_New_5")
  GST_OLD_12_NEW_18 @map("GST_Old_12_new_18")
  GST_OLD_18_NEW_0  @map("GST_Old_18_New_0")
  GST_OLD_18_NEW_40 @map("GST_Old_18_New_40")
  GST_OLD_18_NEW_5  @map("GST_Old_18_New_5")
  GST_OLD_28_NEW_18 @map("GST_Old_28_New_18")
  GST_OLD_28_NEW_40 @map("GST_Old_28_New_40")
  GST_OLD_28_NEW_5  @map("GST_Old_28_New_5")
  GST_OLD_5_NEW_0   @map("GST_Old_5_New_0")
  GST_OLD_5_NEW_18  @map("GST_Old_5_New_18")
}

model User {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String?
  username  String    @unique
  password  String
  createdAt DateTime  @default(now()) @map("created_at")
  lastLogin DateTime? @map("last_login")

  mapSkus             MapSku[]
  marketplaceProducts MarketplaceProduct[]
  ownedShares         SharedAccessUser[]   @relation("SharedOwner")
  memberShares        SharedAccessUser[]   @relation("SharedMember")

  createdVerticals  Vertical[] @relation("VerticalCreatedBy")
  createdCategories Category[] @relation("CategoryCreatedBy")
  createdBaseItems  BaseItem[] @relation("BaseItemCreatedBy")
  createdItems      Item[]     @relation("ItemCreatedBy")
  createdGroups     Group[]    @relation("GroupCreatedBy")

  orderStates      OrdersState[]
  prompts          Prompt[]
  listingTemplates ListingTemplate[]

  @@map("users")
}

model SharedAccessUser {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId      String   @map("owner_user_id") @db.Uuid
  sharedWithUserId String   @map("shared_with_user_id") @db.Uuid
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")

  owner      User @relation("SharedOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  sharedWith User @relation("SharedMember", fields: [sharedWithUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, sharedWithUserId])
  @@index([ownerUserId, isActive], map: "idx_shared_access_owner_active")
  @@index([sharedWithUserId, isActive], map: "idx_shared_access_member_active")
  @@map("shared_access_users")
}

model MapSku {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  oldSku    String   @map("old_sku")
  newSku    String   @map("new_sku")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, oldSku])
  @@index([userId], map: "idx_map_skus_user_id")
  @@index([userId, oldSku], map: "idx_map_skus_old_sku")
  @@map("map_skus")
}

model MarketplaceProduct {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String               @map("user_id") @db.Uuid
  datasetKey String               @map("dataset_key")
  entryType  MarketplaceEntryType @map("entry_type")
  chunkIndex Int?                 @map("chunk_index")
  data       Json
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, datasetKey], map: "idx_marketplace_products_user_dataset")
  @@index([userId, datasetKey, chunkIndex], map: "idx_marketplace_products_user_dataset_chunk")
  @@map("marketplace_products")
}

model Vertical {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  verticalSku String     @unique
  label       String?
  status      StatusEnum @default(SHARED)
  createdBy   String?    @map("created_by") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  creator    User?      @relation("VerticalCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  categories Category[]
  items      Item[]
  groups     Group[]

  @@map("verticals")
}

model Category {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  verticalId  String?    @map("vertical_id") @db.Uuid
  categorySku String
  label       String?
  status      StatusEnum @default(SHARED)
  createdBy   String?    @map("created_by") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  vertical  Vertical?  @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  creator   User?      @relation("CategoryCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  baseItems BaseItem[]
  items     Item[]
  groups    Group[]

  @@unique([verticalId, categorySku])
  @@index([verticalId], map: "idx_categories_vertical_id")
  @@map("categories")
}

model BaseItem {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId String?    @map("category_id") @db.Uuid
  status     StatusEnum @default(SHARED)
  itemName   String     @map("item_name")
  itemSku    String     @map("item_sku")
  createdBy  String?    @map("created_by") @db.Uuid
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  category Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  creator  User?     @relation("BaseItemCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([categoryId, itemSku])
  @@index([categoryId], map: "idx_base_items_category_id")
  @@index([itemSku], map: "idx_base_items_item_sku")
  @@index([createdBy, status], map: "idx_base_items_owner_status")
  @@map("base_items")
}

model Item {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  label             String?
  status            StatusEnum @default(SHARED)
  verticalId        String?    @map("vertical_id") @db.Uuid
  categoryId        String?    @map("category_id") @db.Uuid
  createdBy         String?    @map("created_by") @db.Uuid
  price             Decimal?   @db.Decimal(10, 2)
  quantityPerKg     Decimal?   @map("quantity_per_kg") @db.Decimal(10, 2)
  selfLife          Int?       @map("self_life")
  itemSku           String     @unique @map("item_sku")
  incrementPerRupee Decimal?   @map("increment_per_rupee") @db.Decimal(10, 2)
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  vertical Vertical? @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  creator  User?     @relation("ItemCreatedBy", fields: [createdBy], references: [id])
  groups   Group[]   @relation("GroupItems")

  @@index([verticalId, categoryId], map: "idx_items_vertical_category")
  @@index([createdBy], map: "idx_items_created_by")
  @@index([createdBy, status], map: "idx_items_owner_status")
  @@map("items")
}

model Group {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  label              String?
  status             StatusEnum  @default(SHARED)
  hsn                Int?
  itemIds            String[]    @default([]) @map("item_ids") @db.Uuid
  productsIds        Json        @default("[]") @map("products_ids")
  taxCode            TaxCodeEnum @default(SELECT_ONE) @map("tax_code")
  heightCm           Decimal?    @map("height_cm") @db.Decimal(10, 2)
  lengthCm           Decimal?    @map("length_cm") @db.Decimal(10, 2)
  weightKg           Decimal?    @map("weight_kg") @db.Decimal(10, 2)
  breadthCm          Decimal?    @map("breadth_cm") @db.Decimal(10, 2)
  packagingCost      Decimal?    @map("packaging_cost") @db.Decimal(10, 2)
  finalPriceOver300  Boolean     @default(false) @map("final_price_over_300")
  minQuantityInPiece Int?        @map("min_quantity_in_piece")
  verticalId         String?     @map("vertical_id") @db.Uuid
  categoryId         String?     @map("category_id") @db.Uuid
  createdBy          String?     @map("created_by") @db.Uuid
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  items            Item[]            @relation("GroupItems")
  listingTemplates ListingTemplate[]
  vertical         Vertical?         @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  category         Category?         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  creator          User?             @relation("GroupCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([createdBy, name])
  @@index([createdBy], map: "idx_groups_created_by")
  @@index([createdBy, status], map: "idx_groups_owner_status")
  @@map("groups")
}

model OrdersState {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  status    StatusEnum @default(SHARED)
  stateData Json       @map("state_data")
  createdAt DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)], map: "idx_orders_states_user_created_at")
  @@index([userId, status, createdAt(sort: Desc)], map: "idx_orders_states_user_status_created")
  @@map("orders_states")
}

model Prompt {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  status    StatusEnum @default(SHARED)
  name      String
  value     String?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingTemplates ListingTemplate[]

  @@unique([userId, name])
  @@index([userId], map: "idx_prompt_user_id")
  @@index([userId, status], map: "idx_prompt_user_status")
  @@map("prompt")
}

model ListingTemplate {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  status    StatusEnum @default(SHARED)
  groupId   String?    @map("group_id") @db.Uuid
  promptId  String?    @map("prompt_id") @db.Uuid
  name      String
  color     String?
  json      Json?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  group  Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  prompt Prompt? @relation(fields: [promptId], references: [id], onDelete: SetNull)

  @@index([userId], map: "idx_listing_template_user_id")
  @@index([userId, status], map: "idx_listing_template_user_status")
  @@map("listing_template")
}
